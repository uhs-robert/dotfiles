" vim: set filetype=tridactyl
" --- GENERAL SETTINGS ---
set update.lastchecktime 1772206549053
set update.nag true
set update.nagwait 7
set update.lastnaggedversion 1.14.0
set update.checkintervalsecs 86400
set configversion 2.0
set theme oasis_lagoon
" set newtab https://web.tabliss.io/
set allowautofocus true
set smoothscroll false
set scrollduration 100
set bmarkfoldersearch false
set modeindicatorshowkeys true
set tabopencontaineraware true
set containerindicator false

" --- BINDS ---
"" -- MOVEMENT --
bind h scrollpx -50
bind j scrollline 10
bind k scrollline -10
bind l scrollpx 50
bind H back
bind J tabnext
bind K tabprev
bind L forward
bind $ scrollto 100 x
bind ^ scrollto 0 x

"" -- BASIC --
bind a current_url bmark
bind A bmark
bind b fillcmdline bmarks
bind B fillcmdline bmarks -t
bind f hint
bind F hint -b
bind m gobble 1 markadd
bind M gobble 1 quickmark
bind o fillcmdline open
bind O fillcmdline tabopen
bind p clipboard open
bind P clipboard tabopen
bind r reload
bind R reloadhard
bind t fillcmdline tabopen
bind T fillcmdline tab
bind u undo
bind U undo window
bind v hint -h
bind V mode visual
bind w fillcmdline winopen
bind W current_url winopen
bind . repeat
bind : fillcmdline_notrail
bind << tabmove -1
bind >> tabmove +1
bind [[ followpage prev
bind [c urlincrement -1
bind ]] followpage next
bind ]c urlincrement 1
bind ` gobble 1 markjump

"" -- MODE SWITCH --
bind --mode=browser <A-,> escapehatch
bind <S-Insert> mode ignore
bind <AC-Escape> mode ignore
bind <AC-`> mode ignore
bind <S-Escape> mode ignore
bind <Escape> composite mode normal ; hidecmdline
bind <C-[> composite mode normal ; hidecmdline

"" -- ALT --
bind <A-p> pin
bind <A-m> mute toggle

"" -- CTRL --
bind <C-u> scrollpage -0.5
bind <C-d> scrollpage 0.5
bind <C-f> scrollpage 1
bind <C-b> scrollpage -1
bind <C-v> nmode ignore 1 mode normal
bind <C-o> jumpprev
bind <C-i> jumpnext
bind <C-x> urlincrement -1
bind <C-a> urlincrement 1
unbind --mode=normal <C-y>
" bind <C-y> scrollline -10
unbind --mode=normal <C-e>
" bind <C-e> scrollline 10

"" -- F-KEYS --
bind <F1> help

"" -- YANK --
bind yc clipboard yankcanon
bind ym clipboard yankmd
bind yo clipboard yankorg
bind yq text2qr --timeout 5
bind ys clipboard yankshort
bind yt clipboard yanktitle
bind yy clipboard yank

"" -- GO --
bind G scrollto 100
bind ga tabaudio
bind gg scrollto 0
bind gf viewsource
bind gF hint -qb
bind gh home
bind gH home true
bind gi focusinput
bind go current_url open
bind gO current_url tabopen
bind gt tabnext_gt
bind gT tabprev
bind gu urlparent
bind gU urlroot
bind gx0 tabclosealltoleft
bind gx$ tabclosealltoright
bind g! jumble
bind g$ tablast
bind g0 tabfirst
bind g; changelistjump -1
bind g? rot13
bind g^ tabfirst

"" -- DELETE --
unbind --mode=normal d
bind dd tabclose
bind dL tabclosealltoright
bind dH tabclosealltoleft
bind D js tri.excmds.composite('tabprev;', 'tabclose #')

"" -- X-ECUTABLES --
unbind x
bind xx stop
bind xh js window.wrappedJSObject?.show_knack_id?.api?.toggleShowHidden?.()
bind xi js window.wrappedJSObject?.show_knack_id?.api?.toggleIds?.()
bind xo js (()=>{const s=document.getSelection()?.toString()??'';const q=prompt('Search:',s);if(q!=null)window.wrappedJSObject?.knack_search?.open?.(q);})()
bind xs js (function(){const s=document.createElement('script');s.textContent='Logger?.switch?.()';(document.documentElement?document.documentElement:document.head).appendChild(s);s.remove();})()
bind --mode=visual xv js window.wrappedJSObject?.knack_search?.open?.(document.getSelection()?.toString().trim() ?? '')

"" -- ZOOM --
bind zi zoom 0.1 true
bind zI zoom 3
bind zo zoom -0.1 true
bind zO zoom -3
bind zm zoom 0.5 true
bind zM zoom 0.5 true
bind zr zoom -0.5 true
bind zR zoom -0.5 true
bind zz zoom 1
bind zO zoom 0.3
bind ZZ qall

"" -- HINTS --
""" - MOUSE -
bind ;x hint -F e => { const pos = tri.dom.getAbsoluteCentre(e); tri.excmds.exclaim_quiet("xdotool mousemove --sync " + window.devicePixelRatio * pos.x + " " + window.devicePixelRatio * pos.y + "; xdotool click 1")}
bind ;X hint -F e => { const pos = tri.dom.getAbsoluteCentre(e); tri.excmds.exclaim_quiet("xdotool mousemove --sync " + window.devicePixelRatio * pos.x + " " + window.devicePixelRatio * pos.y + "; xdotool keydown ctrl+shift; xdotool click 1; xdotool keyup ctrl+shift")}
bind ;c hint -F e => { const pos = tri.dom.getAbsoluteCentre(e); tri.excmds.exclaim_quiet("xdotool mousemove --sync " + window.devicePixelRatio * pos.x + " " + window.devicePixelRatio * pos.y + "; xdotool click 3")}
bind ;: hint -F e => { const pos = tri.dom.getAbsoluteCentre(e); tri.excmds.exclaim_quiet("xdotool mousemove --sync " + window.devicePixelRatio * pos.x + " " + window.devicePixelRatio * pos.y)}

""" - REGULAR -
bind ;a hint -a
bind ;A hint -A
bind ;b hint -b
bind ;d hint -W tabopen --discard
" bind ;h hint -h
bind ;i hint -i
" bind ;o hint
bind ;I hint -I
bind ;k hint -k
bind ;K hint -K
bind ;m hint -JFc img i => tri.excmds.open('https://lens.google.com/uploadbyurl?url='+i.src)
bind ;M hint -JFc img i => tri.excmds.tabopen('https://lens.google.com/uploadbyurl?url='+i.src)
bind ;O hint -W fillcmdline_notrail open 
bind ;p hint -p
bind ;P hint -P
bind ;r hint -r
bind ;s hint -s
bind ;S hint -S
bind ;t hint -W tabopen
bind ;T hint -W fillcmdline_notrail tabopen 
bind ;v hint -W mpvsafe
bind ;V hint -V
bind ;w hint -w
bind ;W hint -W fillcmdline_notrail winopen 
bind ;y hint -y
bind ;Y hint -cF img i => tri.excmds.yankimage(tri.urlutils.getAbsoluteURL(i.src))
bind ;; hint -; *
bind ;# hint -#
bind ;z hint -z

""" - Quiet (;g) -
bind ;ga hint -qa
bind ;gA hint -qA
bind ;gb hint -qb
bind ;gd hint -qW tabopen --discard
bind ;gf hint -q
bind ;gF hint -qb
bind ;gi hint -qi
bind ;gI hint -qI
bind ;gk hint -qk
bind ;gp hint -qp
bind ;gP hint -qP
bind ;gr hint -qr
bind ;gs hint -qs
bind ;gS hint -qS
bind ;gv hint -qW mpvsafe
bind ;gw hint -qw
bind ;gy hint -qy
bind ;g; hint -q;
bind ;g# hint -q#

"" -- LEADER --
bind ,, fillcmdline open search
bind ,< fillcmdline tabopen search
bind ,r source

"" -- Ex maps --
bind --mode=ex <A-ArrowDown> ex.next_completion
bind --mode=ex <A-ArrowUp>   ex.prev_completion

" --- Search Ranking ---
set searchurlweight 100000
set bmarkweight 10000

