# swaylock/.config/swaylock/config.template
# Template for swaylock configuration
# Colors are generated by theme/main.lua
# DO NOT EDIT MANUALLY - regenerate with: lua ~/.config/hypr/theme/main.lua

# Behavior
daemonize
show-failed-attempts
clock
screenshot
effect-pixelate=8
effect-vignette=0.25:0.6
font=GohuFont 11 Nerd Font
indicator
indicator-radius=200
indicator-thickness=20

# Base Colors
color=041324
bs-hl-color=F8B471
line-color=0D1D33
ring-color=7FA3C9
inside-color=041324
key-hl-color=F0E68C
separator-color=00000000
text-color=E8F1FF
text-caps-lock-color=""

# Verification State (typing password)
line-ver-color=162945
inside-ver-color=041324
ring-ver-color=8FED88
text-ver-color=8FED88

# Wrong Password State
line-wrong-color=162945
inside-wrong-color=041324
ring-wrong-color=FF7979
text-wrong-color=FF7979

# Clear State (password cleared)
line-clear-color=162945
inside-clear-color=041324
ring-clear-color=F0E68C
text-clear-color=F0E68C

# Grace Period
grace=2
grace-no-mouse
grace-no-touch
datestr=%a, %B %e
timestr=%H:%M:%S
fade-in=0.4
ignore-empty-password
