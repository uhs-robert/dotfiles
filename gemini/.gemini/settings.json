{
  "general": {
    "preferredEditor": "neovim",
    "vimMode": true,
    "sessionRetention": {
      "enabled": true,
      "maxAge": "30d",
      "warningAcknowledged": true
    }
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "ui": {
    "theme": "~/.gemini/theme/oasis_desert_dark.json",
    "showLineNumbers": true,
    "useFullWidth": true,
    "showStatusInTitle": false,
    "showMemoryUsage": true
  },
  "output": {
    "format": "text"
  },
  "tools": {
    "shell": {
      "showColor": true
    }
  }
}